# ============================================================
# Root .gitignore — I-Asset SMBR Monorepo
# ============================================================

# ── Dependencies ──
node_modules/

# ── Environment / Secrets (HARAM DIPUSH) ──
.env
.env.*
!.env.example

# ── OS Files ──
.DS_Store
Thumbs.db
Desktop.ini
*.swp
*.swo
*~

# ── IDE / Editor ──
.vscode/
!.vscode/settings.json
!.vscode/extensions.json
.idea/
*.sublime-workspace
*.sublime-project

# ── Logs ──
*.log
npm-debug.log*
yarn-debug.log*
yarn-error.log*

# ── Expo ──
.expo/

# ── Debug / Test Scripts ──
**/test-*.js
**/debug-*.js
